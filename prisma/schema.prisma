generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Source {
  EDUCATION_GOUV
  UNIV_MONTP3
  HEIDELBERG
}

enum OfferStatus {
  NEW
  SEEN
  INTERESTED
  APPLIED
  REJECTED
}

model JobOffer {
  id           String      @id @default(cuid())
  source       Source
  externalId   String
  title        String
  url          String
  description  String?
  location     String?
  category     String?
  contractType String?
  deadline     DateTime?
  publishedAt  DateTime?
  status       OfferStatus @default(NEW)
  isActive     Boolean     @default(true)
  raw          Json?
  firstSeenAt  DateTime    @default(now())
  lastSeenAt   DateTime    @default(now())
  notifiedAt   DateTime?

  @@unique([source, externalId])
  @@index([status])
  @@index([source, isActive])
}

model ScrapeRun {
  id         String    @id @default(cuid())
  source     Source
  startedAt  DateTime  @default(now())
  finishedAt DateTime?
  ok         Boolean   @default(false)
  found      Int       @default(0)
  added      Int       @default(0)
  error      String?
}
